{
  "name": "angular-crash",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:ssr": "ng build --configuration production && copy dist\\angular-crash\\browser\\index.csr.html dist\\angular-crash\\browser\\index.html",
    "build:ssr:dev": "ng build --configuration development && copy dist\\angular-crash\\browser\\index.csr.html dist\\angular-crash\\browser\\index.html",
    "serve:ssr": "node dist/angular-crash/server/server.mjs",
    "dev:ssr": "npm run build:ssr:dev && npm run serve:ssr",
    "serve:ssr:angular-crash": "node dist/angular-crash/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@angular/common": "^20.2.0",
    "@angular/compiler": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/platform-browser": "^20.2.0",
    "@angular/platform-server": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@angular/ssr": "^20.2.0",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "express": "^4.22.1",
    "json-server": "^1.0.0-beta.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^20.2.0",
    "@angular/cli": "^20.2.0",
    "@angular/compiler-cli": "^20.2.0",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.0",
    "esbuild": "^0.23.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.0",
    "vitest": "^3.2.0"
  }
}